# PostgreSQL connection (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/porcelainvend?schema=public"

# Auth.js / NextAuth v5 — generate: openssl rand -base64 32
AUTH_SECRET=""
# Legacy alias; set to same value as AUTH_SECRET if tooling expects it
NEXTAUTH_SECRET=""

# Public URL of this app — must be a full URL (https://...) for NextAuth.
# Host-only values like app.up.railway.app are auto-prefixed with https:// in code.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Same as above in production; used by Auth.js for redirects
AUTH_URL="http://localhost:3000"

# AES-256-GCM key for SwitchBot + Squarespace API key ciphertext
# 64 hex chars = 32 bytes, e.g. openssl rand -hex 32
ENCRYPTION_KEY=""

# Squarespace OAuth — register a client: https://developers.squarespace.com/oauth
# Redirect URI in Squarespace must match (default: NEXT_PUBLIC_APP_URL + /api/squarespace/oauth/callback)
#SQUARESPACE_OAUTH_CLIENT_ID=""
#SQUARESPACE_OAUTH_CLIENT_SECRET=""
#SQUARESPACE_OAUTH_REDIRECT_URI=""

# Optional: static Bearer for webhook POST only (expires ~30 min; prefer OAuth connect in dashboard)
#SQUARESPACE_WEBHOOK_ACCESS_TOKEN=""
